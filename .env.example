# OpenRouteService — Directions API ONLY (no geocoding)
ORS_API_KEY=your_api_key_here
ORS_REQUEST_TIMEOUT=10
ORS_MAX_RETRIES=1
ROUTE_CACHE_TTL=86400

# Vehicle parameters
VEHICLE_MAX_RANGE_MILES=500
VEHICLE_MPG=10

# Route geometry filter: max miles a station may sit perpendicular to the route
MAX_OFF_ROUTE_MILES=15
